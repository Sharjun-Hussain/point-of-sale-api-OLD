# Server Configuration
NODE_ENV=production
PORT=5000
BACKEND_URL=https://api.your-domain.com
API_VERSION=v1
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=5000
LOG_LEVEL=info
LOG_RETENTION_DAYS=14d

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pos_system
DB_USER=root
DB_PASSWORD=your_db_password
DB_DIALECT=mysql
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Configuration
JWT_SECRET=replace_with_secure_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS - comma separated for multiple origins)
FRONTEND_URL=https://your-domain.com,https://admin.your-domain.com

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Security
BCRYPT_SALT_ROUNDS=10

# Session
SESSION_SECRET=replace_with_session_secret
